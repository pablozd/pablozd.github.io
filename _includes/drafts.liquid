<div class="publications">
  <ol class="bibliography">
    {% for draft in site.data.drafts %}
      <li>
        <div class="row pub-item">
          <div class="col col-sm-2 pub-thumb-col">
            <svg class="pub-thumb-placeholder" width="52" height="67" viewBox="0 0 52 67" xmlns="http://www.w3.org/2000/svg">
              <rect width="52" height="67" fill="#828282" fill-opacity=".08"/>
              <rect x="5" y="5" width="42" height="57" rx="2" fill="var(--global-card-bg-color)" stroke="var(--global-divider-color)" stroke-width=".7"/>
              <rect x="9" y="11" width="26" height="2.5" rx="1" fill="#828282" opacity=".8"/>
              <rect x="9" y="17" width="34" height="1.4" rx=".7" fill="var(--global-text-color)" opacity=".22"/>
              <rect x="9" y="21" width="30" height="1.4" rx=".7" fill="var(--global-text-color)" opacity=".18"/>
              <rect x="9" y="25" width="32" height="1.4" rx=".7" fill="var(--global-text-color)" opacity=".18"/>
              <rect x="9" y="32" width="34" height="1" rx=".5" fill="var(--global-text-color)" opacity=".11"/>
              <rect x="9" y="35" width="28" height="1" rx=".5" fill="var(--global-text-color)" opacity=".11"/>
              <rect x="9" y="38" width="31" height="1" rx=".5" fill="var(--global-text-color)" opacity=".11"/>
              <text x="26" y="58" text-anchor="middle" font-size="6" fill="#828282" font-family="Georgia,serif" font-style="italic">{{ draft.tag[site.active_lang] }}</text>
            </svg>
          </div>
          <div id="draft-{{ forloop.index }}" class="col-sm-8">
            <div class="author">{{ draft.authors }}</div>
            <div class="title">{{ draft.title }}</div>
            <div class="periodical">{{ draft.status[site.active_lang] }}</div>
            <div class="links">
              <a class="abbr-badge btn btn-sm z-depth-0" role="button">{{ draft.tag[site.active_lang] }}</a>
              {% if draft.pdf %}
                <a href="{{ draft.pdf }}" class="btn btn-sm z-depth-0" role="button">PDF</a>
              {% endif %}
            </div>
          </div>
        </div>
      </li>
    {% endfor %}
  </ol>
</div>
