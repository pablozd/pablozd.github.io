<div class="tools-subtitle">{{ site.data[site.active_lang].strings.presentaciones.conferencias }}</div>
<div class="news-list">
  {% for item in site.data.presentaciones.conferencias %}
    <div class="news-item">
      <span class="news-date">{{ item.date }}</span>
      <span class="news-text">{{ item.text }}</span>
    </div>
  {% endfor %}
</div>

