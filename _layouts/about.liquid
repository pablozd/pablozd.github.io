---
layout: default
---
{% if page.banner %}
  <div class="banner-wrap">
    <img src="{{ page.banner.image | prepend: 'assets/img/' | relative_url }}" alt="banner"/>
    <div class="banner-tint"></div>
    <div class="banner-fade-l"></div>
    <div class="banner-fade-r"></div>
    <div class="banner-fade-b"></div>
  </div>
{% endif %}
<div class="post">
  <article>
    {% if page.profile %}
      <div class="profile-row">
        {% if page.profile.image %}
          <div class="avatar-col">
            <div class="avatar">
              {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
              {%
                include figure.liquid loading="eager" path=profile_image_path class="avatar-img" sizes="112px" alt=page.profile.image
                cache_bust=true
              %}
            </div>
            {% if page.profile.more_info %}
              <div class="avatar-more-info">{{ page.profile.more_info }}</div>
            {% endif %}
            {% if site.data.socials.email %}
              <div class="avatar-email">
                <a href="mailto:{{ site.data.socials.email | encode_email }}" class="chip" title="{{ site.data.socials.email }}"><i class="fa-solid fa-envelope"></i>Email</a>
              </div>
            {% endif %}
          </div>
        {% endif %}
        <div class="profile-text">
          <h1 class="post-title">
            {% if site.title == 'blank' %}
              <span class="font-weight-bold">{{ site.first_name }}</span> {{ site.middle_name }}
              {{ site.last_name }}
            {% else %}
              {{ site.title }}
            {% endif %}
          </h1>
          {% if page.profile.role %}
            <div class="role">{{ page.profile.role }}</div>
          {% endif %}

          <div class="clearfix">{{ content }}</div>

          <!-- Social -->
          {% if page.social %}
            <div class="social-row">{% include social_pills.liquid %}</div>
          {% endif %}
        </div>
      </div>
    {% else %}
      <header class="post-header">
        <h1 class="post-title">
          {% if site.title == 'blank' %}
            <span class="font-weight-bold">{{ site.first_name }}</span> {{ site.middle_name }}
            {{ site.last_name }}
          {% else %}
            {{ site.title }}
          {% endif %}
        </h1>
        <p class="desc">{{ page.subtitle }}</p>
      </header>
      <div class="clearfix">{{ content }}</div>
    {% endif %}

    <!-- News -->
    {% if page.announcements and page.announcements.enabled %}
      <div class="section-title">
        <a href="{{ '/news/' | relative_url }}" style="color: inherit">{{ site.data[site.active_lang].strings.news }}</a>
      </div>
      {% include news.liquid limit=true %}
    {% endif %}

    <!-- Latest posts -->
    {% if page.latest_posts and page.latest_posts.enabled %}
      <h2>
        <a href="{{ '/blog/' | relative_url }}" style="color: inherit">{{ site.data[site.active_lang].strings.latest_posts }}</a>
      </h2>
      {% include latest_posts.liquid %}
    {% endif %}

    <!-- Selected papers -->
    {% if page.selected_papers %}
      <div class="section-title">
        <a href="{{ '/publications/' | relative_url }}" style="color: inherit">{{ site.data[site.active_lang].strings.selected_publications }}</a>
      </div>
      {% include selected_papers.liquid %}
    {% endif %}

    <!-- Tools (web apps) -->
    {% if page.tools %}
      {% if site.active_lang == 'en-us' %}
        {% assign tools_url = '/tools/' %}
      {% else %}
        {% assign tools_url = '/herramientas/' %}
      {% endif %}
      <div class="section-title">
        <a href="{{ tools_url | relative_url }}" style="color: inherit">{{ site.data[site.active_lang].strings.tools.web_apps }}</a>
      </div>
      {% include tools.liquid section="apps" %}
    {% endif %}

    {% if site.newsletter and site.newsletter.enabled and site.footer_fixed %}
      {% include newsletter.liquid center=true %}
    {% endif %}
  </article>
</div>
